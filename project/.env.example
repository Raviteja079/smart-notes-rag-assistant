# Smart Notes RAG Assistant configuration

# Choose the LLM provider:
# - "ollama" runs a local model through Ollama.
# - "openai" uses the OpenAI API.
LLM_PROVIDER=ollama

# Ollama settings
# Make sure Ollama is running locally before using the app.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# Optional OpenAI settings
# Only required when LLM_PROVIDER=openai.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Embedding model used for semantic search and RAG retrieval.
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Number of chunks retrieved for search and RAG answers.
TOP_K_RESULTS=4

# Document chunking defaults.
CHUNK_SIZE=900
CHUNK_OVERLAP=180
